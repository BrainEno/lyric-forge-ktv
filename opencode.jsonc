{
  "$schema": "https://opencode.ai/config.json",
  "model": "nvidia/moonshotai/kimi-k2.5",
  "small_model": "ollama/gemma4:latest",
  "instructions": [
    "docs/prd.md",
    "docs/architecture.md",
    "docs/dev-standards.md"
  ],
  "watcher": {
    "ignore": [
      ".git/**",
      "build/**",
      ".dart_tool/**",
      "target/**",
      "node_modules/**",
      ".turbo/**",
      ".idea/**",
      ".vscode/**",
      "dist/**",
      "coverage/**",
      "tmp/**"
    ]
  },
  "permission": {
    "bash": {
      "*": "ask",
      "flutter pub get*": "allow",
      "flutter analyze*": "allow",
      "flutter test*": "allow",
      "dart format*": "allow",
      "cargo test*": "allow",
      "cargo fmt*": "allow",
      "cargo clippy*": "allow",
      "cargo build*": "ask",
      "ffmpeg *": "ask",
      "python *": "ask",
      "git add*": "ask",
      "git commit*": "ask",
      "git push*": "deny",
      "rm *": "deny"
    },
    "skill": {
      "*": "ask",
      "spotify-ui-guard": "allow",
      "flutter-rust-feature-delivery": "allow",
      "lyrics-pipeline-task": "allow",
      "ktv-player-polish": "allow"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  }
}